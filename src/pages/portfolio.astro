---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('portfolio'))
  .sort((a, b) => a.data.order - b.data.order);

const categories = Array.from(new Set(items.map(i => i.data.category)));
---

<BaseLayout title="Portfolio — KristopherAce Photography" description="Selected best work across landscape, astrophotography, travel, and cityscape photography.">
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 pt-16 sm:pt-24 pb-8">
    <p class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-accent)]">Selected work</p>
    <h1 class="mt-3 font-serif text-4xl sm:text-6xl">Portfolio</h1>
    <p class="mt-4 max-w-2xl text-[color:var(--color-ink-300)]">
      The frames I'm proudest of. Updated as I keep shooting.
    </p>

    {categories.length > 1 && (
      <div class="mt-8 flex flex-wrap gap-2 text-xs">
        <button data-filter="all" class="filter-btn active rounded-full border border-[color:var(--color-ink-100)] px-3 py-1.5 text-[color:var(--color-ink-50)]">All</button>
        {categories.map(c => (
          <button data-filter={c} class="filter-btn rounded-full border border-[color:var(--color-ink-700)] px-3 py-1.5 text-[color:var(--color-ink-300)] hover:border-[color:var(--color-ink-100)] hover:text-[color:var(--color-ink-50)]">
            {c.charAt(0).toUpperCase() + c.slice(1)}
          </button>
        ))}
      </div>
    )}
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 pb-24">
    <div id="portfolio-grid" class="masonry">
      {items.map(item => {
        const slug = item.id.replace(/\.(md|mdx)$/, '');
        return (
          <a
            href={`/portfolio/${slug}`}
            class="masonry-item group"
            data-category={item.data.category}
          >
            <img
              src={item.data.image}
              alt={item.data.title}
              loading="lazy"
              decoding="async"
              class="w-full h-auto block transition-opacity duration-300 group-hover:opacity-80"
            />
          </a>
        );
      })}
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const grid = document.getElementById('portfolio-grid')!;

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';
        buttons.forEach(b => {
          b.classList.remove('border-[color:var(--color-ink-100)]', 'text-[color:var(--color-ink-50)]');
          b.classList.add('border-[color:var(--color-ink-700)]', 'text-[color:var(--color-ink-300)]');
        });
        btn.classList.add('border-[color:var(--color-ink-100)]', 'text-[color:var(--color-ink-50)]');
        btn.classList.remove('border-[color:var(--color-ink-700)]', 'text-[color:var(--color-ink-300)]');

        grid.querySelectorAll<HTMLElement>('.masonry-item').forEach(el => {
          const show = filter === 'all' || el.dataset.category === filter;
          el.style.display = show ? 'block' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .masonry {
    columns: 2;
    column-gap: 8px;
  }
  @media (min-width: 640px) {
    .masonry { columns: 3; }
  }
  .masonry-item {
    display: block;
    break-inside: avoid;
    margin-bottom: 8px;
    overflow: hidden;
    border-radius: 2px;
  }
</style>
