---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import exifr from 'exifr';
import path from 'node:path';

export async function getStaticPaths() {
  const items = await getCollection('portfolio');
  return items.map(item => ({
    params: { slug: item.id.replace(/\.(md|mdx)$/, '') },
    props: { item },
  }));
}

const { item } = Astro.props;
const { title, image, caption, category } = item.data;

function formatShutter(exp: number): string {
  if (exp >= 1) return `${exp}s`;
  return `1/${Math.round(1 / exp)}s`;
}

const filePath = path.join(process.cwd(), 'public', image);
let exif: Record<string, any> = {};
try {
  exif = await exifr.parse(filePath, {
    pick: ['Model', 'LensModel', 'FNumber', 'ExposureTime', 'FocalLength', 'ISO', 'DateTimeOriginal']
  }) ?? {};
} catch {}

const shotOn = exif.DateTimeOriginal ? new Date(exif.DateTimeOriginal) : null;
const specs = [
  exif.FocalLength ? `${exif.FocalLength}mm` : null,
  exif.FNumber ? `f/${exif.FNumber}` : null,
  exif.ExposureTime ? formatShutter(exif.ExposureTime) : null,
  exif.ISO ? `ISO ${exif.ISO}` : null,
].filter(Boolean);
---

<BaseLayout title={`${title} — KristopherAce Photography`} description={caption ?? title} image={image}>

  <!-- Photo stage: fills the viewport, photo always fits -->
  <div class="photo-stage">
    <a href="/portfolio" class="back-link">← Portfolio</a>
    <div class="photo-inner">
      <img src={image} alt={title} class="photo-img" />
    </div>
  </div>

  <!-- Info below the fold -->
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-10 py-12">
    <div class="flex items-baseline gap-4 flex-wrap">
      <h1 class="font-serif text-3xl sm:text-4xl">{title}</h1>
      <span class="text-xs uppercase tracking-widest text-[color:var(--color-accent)]">{category}</span>
    </div>

    {caption && <p class="mt-3 text-[color:var(--color-ink-400)] text-sm">{caption}</p>}

    {shotOn && (
      <p class="mt-2 text-sm text-[color:var(--color-ink-400)]">
        {shotOn.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </p>
    )}

    {(exif.Model || exif.LensModel || specs.length > 0) && (
      <div class="mt-6 pt-6 border-t border-[color:var(--color-ink-700)] space-y-2">
        <div class="flex flex-wrap gap-x-6 gap-y-1 text-sm text-[color:var(--color-ink-400)]">
          {exif.Model && (
            <span class="flex gap-2">
              <span class="text-[color:var(--color-ink-600)] uppercase tracking-widest text-xs">Camera</span>
              {exif.Model}
            </span>
          )}
          {exif.LensModel && (
            <span class="flex gap-2">
              <span class="text-[color:var(--color-ink-600)] uppercase tracking-widest text-xs">Lens</span>
              {exif.LensModel}
            </span>
          )}
        </div>
        {specs.length > 0 && (
          <p class="text-sm text-[color:var(--color-ink-400)] tracking-wide">{specs.join(' · ')}</p>
        )}
      </div>
    )}
  </div>

</BaseLayout>

<style>
  .photo-stage {
    position: relative;
    width: 100%;
    height: 100vh;
  }

  .photo-inner {
    position: absolute;
    top: 120px;
    bottom: 24px;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
  }

  .back-link {
    position: absolute;
    top: 128px;
    left: 24px;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: rgba(255,255,255,0.9); }
</style>
