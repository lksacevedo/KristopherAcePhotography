---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const albums = (await getCollection('albums'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Data shipped to the client for pin rendering
const albumData = albums.map(a => ({
  slug: a.id.replace(/\.(md|mdx)$/, ''),
  title: a.data.title,
  location: a.data.location,
  coordinates: a.data.coordinates,
  cover: a.data.cover,
  excerpt: a.data.excerpt ?? '',
  date: a.data.date.toISOString(),
}));

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? '';
---

<BaseLayout
  title="Albums — Explore by Location — KristopherAce Photography"
  description="An interactive map of every location I've shot. Click a pin to open the album."
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 pt-16 sm:pt-20 pb-6">
    <p class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-accent)]">Albums</p>
    <h1 class="mt-3 font-serif text-4xl sm:text-6xl">Explore by location.</h1>
    <p class="mt-4 max-w-2xl text-[color:var(--color-ink-300)]">
      Every album is pinned to where it was shot. Click a pin to open that collection.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 pb-24">
    {!mapboxToken && (
      <div class="rounded-sm border border-[color:var(--color-ink-700)] bg-[color:var(--color-ink-900)] p-4 mb-6 text-sm text-[color:var(--color-ink-300)]">
        Add <code class="text-[color:var(--color-ink-50)]">PUBLIC_MAPBOX_TOKEN</code> to <code class="text-[color:var(--color-ink-50)]">.env</code> to enable the map.
      </div>
    )}

    <div class="relative">
      <div id="album-map" class="h-[70vh] min-h-[500px] w-full rounded-sm bg-[color:var(--color-ink-900)] ring-1 ring-[color:var(--color-ink-800)]"></div>
    </div>

    <!-- Fallback list, always visible below the map -->
    <div class="mt-12">
      <h2 class="font-serif text-2xl">All albums</h2>
      <ul class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {albums.map(a => {
          const slug = a.id.replace(/\.(md|mdx)$/, '');
          return (
            <li>
              <a href={`/albums/${slug}`} class="group block overflow-hidden rounded-sm bg-[color:var(--color-ink-800)] ring-1 ring-[color:var(--color-ink-800)] hover:ring-[color:var(--color-ink-500)] transition">
                <div class="aspect-[3/2] overflow-hidden">
                  <img src={a.data.cover} alt={a.data.title} loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
                </div>
                <div class="px-4 py-3">
                  <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-ink-500)]">{a.data.location}</p>
                  <h3 class="mt-1 font-serif text-lg">{a.data.title}</h3>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.9.0/mapbox-gl.css" />

  <script is:inline define:vars={{ albumData, mapboxToken }}>
    window.__ALBUMS__ = albumData;
    window.__MAPBOX_TOKEN__ = mapboxToken;
  </script>

  <!-- Load Mapbox GL via CDN so we don't need to bundle it -->
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.9.0/mapbox-gl.js" is:inline></script>
  <script is:inline>
    (function initMap() {
      const token = window.__MAPBOX_TOKEN__;
      const albums = window.__ALBUMS__ || [];
      if (!token || typeof mapboxgl === 'undefined' || albums.length === 0) return;

      mapboxgl.accessToken = token;
      const map = new mapboxgl.Map({
        container: 'album-map',
        style: 'mapbox://styles/mapbox/dark-v11',
        center: [0, 20],
        zoom: 1.3,
        projection: 'globe',
        attributionControl: { compact: true },
      });

      map.on('style.load', () => {
        map.setFog({
          color: '#0a0a0b',
          'high-color': '#1a1530',
          'horizon-blend': 0.1,
          'space-color': '#05050a',
          'star-intensity': 0.6,
        });
      });

      map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), 'top-right');

      const geojson = {
        type: 'FeatureCollection',
        features: albums.map(a => ({
          type: 'Feature',
          geometry: { type: 'Point', coordinates: a.coordinates },
          properties: { ...a },
        })),
      };

      map.on('load', () => {
        map.addSource('albums', {
          type: 'geojson',
          data: geojson,
          cluster: true,
          clusterRadius: 40,
          clusterMaxZoom: 6,
        });

        map.addLayer({
          id: 'clusters',
          type: 'circle',
          source: 'albums',
          filter: ['has', 'point_count'],
          paint: {
            'circle-color': '#e6c98a',
            'circle-radius': ['step', ['get', 'point_count'], 16, 5, 22, 20, 28],
            'circle-stroke-width': 2,
            'circle-stroke-color': '#0a0a0b',
          },
        });

        map.addLayer({
          id: 'cluster-count',
          type: 'symbol',
          source: 'albums',
          filter: ['has', 'point_count'],
          layout: {
            'text-field': ['get', 'point_count_abbreviated'],
            'text-font': ['DIN Offc Pro Medium', 'Arial Unicode MS Bold'],
            'text-size': 12,
          },
          paint: { 'text-color': '#0a0a0b' },
        });

        map.addLayer({
          id: 'album-pins',
          type: 'circle',
          source: 'albums',
          filter: ['!', ['has', 'point_count']],
          paint: {
            'circle-color': '#e6c98a',
            'circle-radius': 7,
            'circle-stroke-width': 2,
            'circle-stroke-color': '#0a0a0b',
          },
        });

        map.on('click', 'clusters', (e) => {
          const features = map.queryRenderedFeatures(e.point, { layers: ['clusters'] });
          const clusterId = features[0].properties.cluster_id;
          map.getSource('albums').getClusterExpansionZoom(clusterId, (err, zoom) => {
            if (err) return;
            map.easeTo({ center: features[0].geometry.coordinates, zoom });
          });
        });

        map.on('click', 'album-pins', (e) => {
          const f = e.features[0];
          const p = f.properties;
          const html = `
            <a href="/albums/${p.slug}" style="display:block;color:inherit;text-decoration:none;">
              <img src="${p.cover}" alt="" style="width:100%;height:140px;object-fit:cover;border-radius:2px;margin-bottom:8px;" />
              <div style="font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#6b6b76;">${p.location}</div>
              <div style="font-family:Georgia,serif;font-size:16px;margin-top:2px;color:#f5f5f7;">${p.title}</div>
              ${p.excerpt ? `<div style="font-size:12px;color:#b8b8c2;margin-top:4px;">${p.excerpt}</div>` : ''}
              <div style="margin-top:8px;font-size:11px;color:#e6c98a;">Open album →</div>
            </a>
          `;
          new mapboxgl.Popup({ offset: 14, closeButton: true, maxWidth: '260px', className: 'album-popup' })
            .setLngLat(f.geometry.coordinates)
            .setHTML(html)
            .addTo(map);
        });

        map.on('mouseenter', 'album-pins', () => { map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', 'album-pins', () => { map.getCanvas().style.cursor = ''; });
        map.on('mouseenter', 'clusters', () => { map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', 'clusters', () => { map.getCanvas().style.cursor = ''; });
      });
    })();
  </script>

  <style is:global>
    .mapboxgl-popup-content {
      background: #111114 !important;
      color: #e8e8ee !important;
      border: 1px solid #22222a;
      border-radius: 4px;
      padding: 12px !important;
    }
    .mapboxgl-popup-tip { border-top-color: #111114 !important; border-bottom-color: #111114 !important; }
    .mapboxgl-popup-close-button { color: #b8b8c2 !important; font-size: 20px !important; padding: 2px 6px !important; }
    .mapboxgl-ctrl-attrib { background: rgba(10,10,11,0.6) !important; color: #6b6b76 !important; }
    .mapboxgl-ctrl-attrib a { color: #b8b8c2 !important; }
  </style>
</BaseLayout>
