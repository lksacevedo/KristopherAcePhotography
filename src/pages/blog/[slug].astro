---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', p => !p.data.draft);
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — KristopherAce Photography`}
  description={post.data.excerpt ?? post.data.title}
  image={post.data.cover ?? '/og-default.jpg'}
>
  <article class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-10 pt-16 sm:pt-24 pb-24">
    <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-ink-500)]">
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </time>
      {post.data.tags.length > 0 && (
        <span> · {post.data.tags.join(' · ')}</span>
      )}
    </div>

    <h1 class="mt-3 font-serif text-4xl sm:text-5xl leading-[1.1]">{post.data.title}</h1>

    {post.data.cover && (
      <img src={post.data.cover} alt="" class="mt-8 w-full rounded-sm" />
    )}

    <div class="prose prose-invert mt-10 max-w-none text-[color:var(--color-ink-300)] prose-headings:font-serif prose-headings:text-[color:var(--color-ink-50)] prose-a:text-[color:var(--color-accent)] prose-strong:text-[color:var(--color-ink-50)]">
      <Content />
    </div>

    <div class="mt-16 border-t border-[color:var(--color-ink-800)] pt-8">
      <a href="/blog" class="text-sm text-[color:var(--color-ink-300)] hover:text-[color:var(--color-accent)]">← All posts</a>
    </div>
  </article>
</BaseLayout>
