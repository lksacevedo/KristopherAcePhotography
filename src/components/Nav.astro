---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/albums', label: 'Albums' },
  { href: '/blog', label: 'Journal' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-[color:var(--color-ink-800)] bg-[color:var(--color-ink-950)]/80 backdrop-blur supports-[backdrop-filter]:bg-[color:var(--color-ink-950)]/60">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-10 h-16">
    <a href="/" class="group flex items-baseline gap-2">
      <span class="font-serif text-xl tracking-tight text-[color:var(--color-ink-50)] group-hover:text-[color:var(--color-accent)] transition-colors">KristopherAce</span>
      <span class="hidden sm:inline text-[11px] uppercase tracking-[0.2em] text-[color:var(--color-ink-500)]">Photography</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={`relative py-1 transition-colors ${
            isActive(href)
              ? 'text-[color:var(--color-accent)]'
              : 'text-[color:var(--color-ink-300)] hover:text-[color:var(--color-ink-50)]'
          }`}
        >
          {label}
          {isActive(href) && (
            <span class="absolute -bottom-px left-0 right-0 h-px bg-[color:var(--color-accent)]"></span>
          )}
        </a>
      ))}
    </nav>

    <button
      type="button"
      id="nav-toggle"
      aria-label="Toggle menu"
      class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded border border-[color:var(--color-ink-700)] text-[color:var(--color-ink-300)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-[color:var(--color-ink-800)] bg-[color:var(--color-ink-950)]">
    <nav class="flex flex-col px-4 py-3 text-sm">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={`py-2 ${isActive(href) ? 'text-[color:var(--color-accent)]' : 'text-[color:var(--color-ink-300)]'}`}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
