---
const { pathname } = Astro.url;
const links = [
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/gallery',   label: 'Gallery'   },
  { href: '/albums',    label: 'Albums'    },
  { href: '/blog',      label: 'Journal'   },
  { href: '/about',     label: 'About'     },
  { href: '/contact',   label: 'Contact'   },
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const isHome = pathname === '/';
---

{!isHome && (
  <header class="site-header">
    <!-- Logo top left -->
    <a href="/" class="header-logo" aria-label="KristopherAce Home">
      <img src="/logo-ka-white.svg" alt="KA Logo" width="44" height="44" />
    </a>

    <!-- Desktop: nav links permanently down the right side -->
    <nav class="side-nav" aria-label="Main navigation">
      {links.map(({ href, label }) => (
        <a href={href} class={isActive(href) ? 'active' : ''}>
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile only: hamburger button -->
    <button
      id="nav-toggle"
      class="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Mobile only: slide-in panel -->
    <nav id="mobile-menu" class="mobile-menu" aria-hidden="true">
      <button id="nav-close" class="nav-close" aria-label="Close menu">&#x2715;</button>
      <ul>
        {links.map(({ href, label }) => (
          <li>
            <a href={href} class={isActive(href) ? 'active' : ''}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div id="nav-backdrop" class="nav-backdrop" aria-hidden="true"></div>
  </header>
)}

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    pointer-events: none;
  }

  /* ── LOGO: top left ── */
  .header-logo {
    position: absolute;
    top: 20px;
    left: 24px;
    pointer-events: all;
  }
  .header-logo img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.8));
    transition: opacity 0.2s;
  }
  .header-logo:hover img { opacity: 0.7; }

  /* ── DESKTOP SIDE NAV ── */
  .side-nav {
    position: absolute;
    top: 50%;
    right: 32px;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 18px;
    pointer-events: all;
  }
  .side-nav a {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .side-nav a:hover { color: rgba(255, 255, 255, 0.9); }
  .side-nav a.active { color: #fff; }

  /* ── HAMBURGER: mobile only ── */
  .hamburger {
    display: none;
    position: absolute;
    top: 18px;
    right: 20px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    cursor: pointer;
    pointer-events: all;
    transition: background 0.2s;
  }
  .hamburger:hover { background: rgba(0, 0, 0, 0.65); }
  .hamburger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #ddd;
    border-radius: 2px;
  }

  /* ── MOBILE SLIDE-IN PANEL ── */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(280px, 85vw);
    z-index: 200;
    background: rgba(8, 8, 8, 0.97);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px 36px;
    pointer-events: all;
  }
  .mobile-menu.open { transform: translateX(0); }

  .nav-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.4);
    font-size: 18px;
    cursor: pointer;
    padding: 8px;
    line-height: 1;
    transition: color 0.2s;
  }
  .nav-close:hover { color: #fff; }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mobile-menu a {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: rgba(255, 255, 255, 0.9); }
  .mobile-menu a.active { color: #fff; }

  /* ── BACKDROP ── */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .nav-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── RESPONSIVE BREAKPOINT ── */
  @media (max-width: 768px) {
    .side-nav   { display: none; }
    .hamburger  { display: flex; }
  }
</style>

<script>
  const toggle   = document.getElementById('nav-toggle');
  const closeBtn = document.getElementById('nav-close');
  const menu     = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('nav-backdrop');

  function openNav() {
    menu?.classList.add('open');
    backdrop?.classList.add('open');
    toggle?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
  }
  function closeNav() {
    menu?.classList.remove('open');
    backdrop?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
  }

  toggle?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  backdrop?.addEventListener('click', closeNav);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeNav();
  });
</script>
