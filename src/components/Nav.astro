---
const { pathname } = Astro.url;
const links = [
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/gallery',   label: 'Gallery'   },
  { href: '/albums',    label: 'Albums'    },
  { href: '/blog',      label: 'Journal'   },
  { href: '/about',     label: 'About'     },
  { href: '/contact',   label: 'Contact'   },
];
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

// Hide the fixed nav on the home page — the hero handles it there
const isHome = pathname === '/';
---

{!isHome && (
  <>
    <!-- TOP BAR: logo left, hamburger right -->
    <header id="site-header" class="site-header">
      <a href="/" class="header-logo" aria-label="KristopherAce Home">
        <img src="/ka-logo.svg" alt="KA Logo" width="44" height="44" />
      </a>

      <button
        id="nav-toggle"
        class="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="side-nav"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </header>

    <!-- SIDE NAV: slides in from right -->
    <nav id="side-nav" class="side-nav" aria-hidden="true">
      <button id="nav-close" class="nav-close" aria-label="Close menu">&#x2715;</button>
      <ul>
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={isActive(href) ? 'active' : ''}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Backdrop -->
    <div id="nav-backdrop" class="nav-backdrop" aria-hidden="true"></div>
  </>
)}

<style>
  /* ── TOP BAR ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    /* subtle gradient so it doesn't fight page content */
    background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 100%);
    pointer-events: none; /* let clicks through the gradient area */
  }

  .header-logo,
  .hamburger {
    pointer-events: all;
  }

  .header-logo img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.8));
    transition: opacity 0.2s;
  }
  .header-logo:hover img { opacity: 0.8; }

  /* ── HAMBURGER ── */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .hamburger:hover { background: rgba(0, 0, 0, 0.65); }
  .hamburger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #ddd;
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  /* ── SIDE NAV ── */
  .side-nav {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(280px, 85vw);
    z-index: 200;
    background: rgba(8, 8, 8, 0.97);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px 36px;
  }
  .side-nav.open {
    transform: translateX(0);
  }

  .nav-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.4);
    font-size: 18px;
    cursor: pointer;
    padding: 8px;
    line-height: 1;
    transition: color 0.2s;
  }
  .nav-close:hover { color: #fff; }

  .side-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .side-nav a {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .side-nav a:hover {
    color: rgba(255, 255, 255, 0.9);
  }
  .side-nav a.active {
    color: #fff;
    border-bottom-color: rgba(255,255,255,0.2);
  }

  /* ── BACKDROP ── */
  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .nav-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }
</style>

<script>
  const toggle   = document.getElementById('nav-toggle');
  const closeBtn = document.getElementById('nav-close');
  const nav      = document.getElementById('side-nav');
  const backdrop = document.getElementById('nav-backdrop');

  function openNav() {
    nav?.classList.add('open');
    backdrop?.classList.add('open');
    toggle?.setAttribute('aria-expanded', 'true');
    nav?.setAttribute('aria-hidden', 'false');
  }
  function closeNav() {
    nav?.classList.remove('open');
    backdrop?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    nav?.setAttribute('aria-hidden', 'true');
  }

  toggle?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  backdrop?.addEventListener('click', closeNav);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeNav();
  });
</script>
