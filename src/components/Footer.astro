---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[color:var(--color-ink-800)] bg-[color:var(--color-ink-950)]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-12 grid gap-10 md:grid-cols-3">
    <div>
      <p class="font-serif text-lg text-[color:var(--color-ink-50)]">KristopherAce Photography</p>
      <p class="mt-2 text-sm text-[color:var(--color-ink-500)] max-w-sm">
        Landscape, astrophotography, and travel. Prints and bookings coming soon.
      </p>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-ink-500)]">Explore</p>
      <ul class="mt-3 space-y-2 text-sm text-[color:var(--color-ink-300)]">
        <li><a href="/portfolio" class="hover:text-[color:var(--color-accent)]">Portfolio</a></li>
        <li><a href="/gallery" class="hover:text-[color:var(--color-accent)]">Recent gallery</a></li>
        <li><a href="/albums" class="hover:text-[color:var(--color-accent)]">Albums (map)</a></li>
        <li><a href="/blog" class="hover:text-[color:var(--color-accent)]">Journal</a></li>
      </ul>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-ink-500)]">Elsewhere</p>
      <ul class="mt-3 space-y-2 text-sm text-[color:var(--color-ink-300)]">
        <li><a href="https://instagram.com/" target="_blank" rel="noopener" class="hover:text-[color:var(--color-accent)]">Instagram</a></li>
        <li><a href="/contact" class="hover:text-[color:var(--color-accent)]">Contact</a></li>
        <li><a href="/rss.xml" class="hover:text-[color:var(--color-accent)]">RSS</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[color:var(--color-ink-800)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-5 flex items-center justify-between text-xs text-[color:var(--color-ink-500)]">
      <p>&copy; {year} Kristopher Acevedo. All photographs are original work.</p>
      <p class="hidden sm:block">Built with Astro.</p>
    </div>
  </div>
</footer>
