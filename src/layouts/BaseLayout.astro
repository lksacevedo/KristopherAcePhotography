---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'KristopherAce Photography',
  description = 'Landscape, astrophotography, and travel photography by Kristopher Acevedo.',
  image = '/og-default.jpg',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://kristopheracephotography.co').toString();
---

<!doctype html>
<html lang="en" class="bg-[color:var(--color-ink-950)]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.url).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url).toString()} />

    <!-- Fonts: Inter + Fraunces (variable) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="alternate" type="application/rss+xml" title="KristopherAce Journal" href="/rss.xml" />
  </head>
  <body class="flex min-h-screen flex-col bg-[color:var(--color-ink-950)] text-[color:var(--color-ink-100)]">
    <Nav />
    <main class="flex-1 fade-in">
      <slot />
    </main>
    <Footer />
  </body>
</html>
